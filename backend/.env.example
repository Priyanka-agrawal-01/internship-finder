# InternPulse Backend Configuration

# Server Configuration
PORT=5000
NODE_ENV=development

# Allowed Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Nodemailer Configuration (Optional)
# If left blank, the server will automatically generate a mock Ethereal mail account
# for testing subscriptions, and log the test inbox links to the console.
#
# To use a real email service (like Gmail or Outlook):
# EMAIL_SERVICE=gmail
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password
